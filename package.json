{
  "name": "discord-guardian-bot",
  "version": "2.0.0",
  "description": "Bot de Discord premium para moderación, seguridad y gestión de comunidades",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "ts-node prisma/seed.ts",
    "deploy:commands": "ts-node src/handlers/deployCommands.ts",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f bot"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "discord.js": "^14.15.3",
    "openai": "^4.52.7",
    "ioredis": "^5.4.1",
    "winston": "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8",
    "node-cron": "^3.0.3",
    "sharp": "^0.33.4",
    "canvas": "^2.11.2",
    "html-pdf-node": "^1.0.8",
    "rate-limiter-flexible": "^5.0.3",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "uuid": "^10.0.0",
    "date-fns": "^3.6.0",
    "ms": "^2.1.3",
    "axios": "^1.7.2",
    "cheerio": "^1.0.0",
    "bad-words": "^3.0.4",
    "compromise": "^14.14.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/bcryptjs": "^2.4.6",
    "@types/uuid": "^10.0.0",
    "@types/ms": "^0.7.34",
    "@types/cors": "^2.8.17",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "@typescript-eslint/parser": "^7.15.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.2",
    "prisma": "^5.14.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
