const RATE_LIMIT_WINDOW = parseInt(process.env['RATE_LIMIT_WINDOW'] ?? '60000') / 1000;
const RATE_LIMIT_MAX = parseInt(process.env['RATE_LIMIT_MAX'] ?? '30');

const event: Event = {
